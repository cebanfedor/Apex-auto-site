{
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/auctions", "destination": "/auctions.html" },
    { "source": "/auctions/:slug", "destination": "/api/lot-page?slug=:slug" },
    { "source": "/tracking", "destination": "/tracking.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contacts", "destination": "/contacts.html" },
    { "source": "/hot", "destination": "/hot.html" },
    { "source": "/guide", "destination": "/guide.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
